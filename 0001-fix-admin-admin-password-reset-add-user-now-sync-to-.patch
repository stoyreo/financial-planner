+// ─── GoTrue admin REST helpers ─────────────────────────────────────
+async function authAdminCreateUser(
+  url: string,
+  key: string,
+  email: string,
+  password: string,
+  metadata: Record<string, unknown>,
+): Promise<{ id: string } | { error: string }> {
+  const res = await fetch(`${url}/auth/v1/admin/users`, {
+    method: "POST",
+    headers: sbHeaders(key),
+    body: JSON.stringify({ email, password, email_confirm: true, user_metadata: metadata }),
+  });
+  const text = await res.text();
+  if (!res.ok) return { error: `auth.admin.createUser ${res.status}: ${text}` };
+  try {
+    const j = JSON.parse(text);
+    if (!j?.id) return { error: `auth.admin.createUser missing id: ${text}` };
+    return { id: j.id };
+  } catch {
+    return { error: `auth.admin.createUser non-json: ${text}` };
+  }
+}
+
+async function authAdminUpdatePassword(
+  url: string,
+  key: string,
+  authUserId: string,
+  newPassword: string,
+): Promise<{ ok: true } | { error: string }> {
+  const res = await fetch(`${url}/auth/v1/admin/users/${encodeURIComponent(authUserId)}`, {
+    method: "PUT",
+    headers: sbHeaders(key),
+    body: JSON.stringify({ password: newPassword }),
+  });
+  if (!res.ok) return { error: `auth.admin.updateUser ${res.status}: ${await res.text()}` };
+  return { ok: true };
+}
+
+async function authAdminDeleteUser(url: string, key: string, authUserId: string): Promise<void> {
+  await fetch(`${url}/auth/v1/admin/users/${encodeURIComponent(authUserId)}`, {
+    method: "DELETE",
+    headers: sbHeaders(key),
+  }).catch(() => {});
+}
+
+async function authAdminFindByEmail(url: string, key: string, email: string): Promise<string | null> {
+  const target = String(email).toLowerCase();
+  let page = 1;
+  while (page < 20) {
+    const res = await fetch(`${url}/auth/v1/admin/users?page=${page}&per_page=200`, {
+      headers: sbHeaders(key),
+    });
+    if (!res.ok) return null;
+    const j: any = await res.json().catch(() => ({}));
+    const users: any[] = j?.users ?? [];
+    if (!users.length) return null;
+    const hit = users.find((u) => String(u.email ?? "").toLowerCase() === target);
+    if (hit?.id) return hit.id;
+    if (users.length < 200) return null;
+    page++;
+  }
+  return null;
+}
